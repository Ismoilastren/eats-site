{
  "expo": {
    "name": "ExpressEats",
    "slug": "express-eats-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "expresseats",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.expresseats.client"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF6B35"
      },
      "package": "com.expresseats.client"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "2(13) uses your location to create delivery orders and show courier tracking."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
