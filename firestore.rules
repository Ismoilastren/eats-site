rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // HELPER FUNCTIONS
    // =============================================
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserRole() {
      let docRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(docRef) ? get(docRef).data.role : null;
    }

    function isAdmin() {
      return isAuth() && getUserRole() in ['admin', 'superadmin'];
    }

    function isCourier() {
      return isAuth() && getUserRole() == 'courier';
    }

    function isRestaurantOwner(restaurantId) {
      return isAuth() &&
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid;
    }

    function hasAssignedCourierId(data) {
      return data.assignedCourier is map &&
        data.assignedCourier.id is string &&
        data.assignedCourier.id.size() > 0;
    }

    function isAssignedCourier() {
      return isAuth() && (
        resource.data.courierId == request.auth.uid ||
        (hasAssignedCourierId(resource.data) &&
          resource.data.assignedCourier.id == request.auth.uid)
      );
    }

    function isUnassignedRadarOrder() {
      return resource.data.status == 'ready_for_pickup' &&
        resource.data.courierId == null &&
        resource.data.assignedCourier == null;
    }

    function isClientCreatedOrder() {
      return request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.courierId == null &&
        request.resource.data.assignedCourier == null;
    }

    function isPublicDemoOrderCreate() {
      return request.resource.data.status == 'pending' &&
        request.resource.data.courierId == null &&
        request.resource.data.assignedCourier == null &&
        request.resource.data.restaurantId is string &&
        request.resource.data.customerName is string &&
        request.resource.data.customerPhone is string;
    }

    function isPublicDemoOrderUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'statusHistory',
        'assignedCourier',
        'courier',
        'courierId',
        'courierName',
        'courierPhone',
        'courierLocation',
        'deliveredAt',
        'cancelledAt',
        'cancelReason',
        'updatedAt'
      ]) &&
      request.resource.data.status in [
        'pending',
        'accepted',
        'preparing',
        'ready_for_pickup',
        'picked_up',
        'on_the_way',
        'delivered',
        'cancelled',
        'rejected'
      ];
    }

    function isPublicCourierOperationalUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'isOnline',
        'isAvailable',
        'currentLocation',
        'currentOrderId',
        'lastSeenAt',
        'updatedAt'
      ]) &&
      request.resource.data.status in ['offline', 'online', 'busy'] &&
      request.resource.data.isOnline is bool &&
      (
        (request.resource.data.status == 'offline' &&
          request.resource.data.isOnline == false) ||
        (request.resource.data.status in ['online', 'busy'] &&
          request.resource.data.isOnline == true)
      ) &&
      (
        request.resource.data.status != 'busy' ||
        request.resource.data.currentOrderId is string
      );
    }

    function isClientCancelOnly() {
      return resource.data.userId == request.auth.uid &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'cancelled' &&
        request.resource.data.courierId == resource.data.courierId &&
        request.resource.data.assignedCourier == resource.data.assignedCourier &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'cancelledAt',
          'cancelReason',
          'updatedAt'
        ]);
    }

    function isClientReviewOnly() {
      return resource.data.userId == request.auth.uid &&
        resource.data.status == 'delivered' &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.courierId == resource.data.courierId &&
        request.resource.data.assignedCourier == resource.data.assignedCourier &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'review',
          'tipAmount',
          'updatedAt'
        ]);
    }

    function isCourierAcceptOnly() {
      return isCourier() &&
        isUnassignedRadarOrder() &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.courierId == request.auth.uid &&
        hasAssignedCourierId(request.resource.data) &&
        request.resource.data.assignedCourier.id == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'courierId',
          'courierName',
          'courierPhone',
          'assignedCourier',
          'updatedAt'
        ]);
    }

    function isAssignedCourierDeliveryUpdate() {
      return isAssignedCourier() &&
        !(resource.data.status in ['delivered', 'cancelled', 'rejected']) &&
        request.resource.data.courierId == resource.data.courierId &&
        request.resource.data.assignedCourier == resource.data.assignedCourier &&
        request.resource.data.status in [
          'ready_for_pickup',
          'picked_up',
          'on_the_way',
          'delivered'
        ] &&
        (
          request.resource.data.status == resource.data.status ||
          (resource.data.status == 'ready_for_pickup' &&
            request.resource.data.status == 'picked_up') ||
          (resource.data.status == 'picked_up' &&
            request.resource.data.status == 'on_the_way') ||
          (resource.data.status == 'on_the_way' &&
            request.resource.data.status == 'delivered')
        ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'courierLocation',
          'deliveredAt',
          'updatedAt'
        ]);
    }

    function isRestaurantStatusOnly() {
      return isRestaurantOwner(resource.data.restaurantId) &&
        request.resource.data.restaurantId == resource.data.restaurantId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.courierId == resource.data.courierId &&
        request.resource.data.assignedCourier == resource.data.assignedCourier &&
        request.resource.data.status in [
          'pending',
          'accepted',
          'preparing',
          'ready_for_pickup',
          'cancelled',
          'rejected'
        ] &&
        (
          request.resource.data.status == resource.data.status ||
          (resource.data.status == 'pending' &&
            request.resource.data.status in ['accepted', 'cancelled', 'rejected']) ||
          (resource.data.status == 'accepted' &&
            request.resource.data.status in ['preparing', 'cancelled']) ||
          (resource.data.status == 'preparing' &&
            request.resource.data.status in ['ready_for_pickup', 'cancelled'])
        ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt'
        ]);
    }

    // =============================================
    // USERS COLLECTION
    // =============================================
    match /users/{userId} {
      // Users can read their own profile; admins can read all
      allow read: if isAuth() && (isOwner(userId) || isAdmin());
      // Users can create their own profile
      allow create: if isAuth() && isOwner(userId);
      // Users can update their own profile; admins can update any
      allow update: if isAuth() && (isOwner(userId) || isAdmin());
      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // =============================================
    // RESTAURANTS COLLECTION
    // =============================================
    match /restaurants/{restaurantId} {
      // Public read — anyone can browse restaurants
      allow read: if true;
      // Only admins can create restaurants (temporarily relaxed for debugging)
      allow create: if isAuth();
      // Authenticated admin-panel/demo tools can update restaurants.
      allow update: if isAuth();
      // Only admins can delete
      allow delete: if isAdmin();

      // Menu Items (subcollection)
      match /menuItems/{itemId} {
        // Public read
        allow read: if true;
        // Authenticated admin-panel/demo tools can write menu items.
        allow write: if isAuth();
      }

      match /dishes/{dishId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }

    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /promos/{promoId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // =============================================
    // ORDERS COLLECTION
    // =============================================
    match /orders/{orderId} {
      // Read: order owner, assigned courier, restaurant owner, or admin
      allow read: if true;
      // Clients must create orders as pending and explicitly unassigned.
      allow create: if isPublicDemoOrderCreate() || (isAuth() && isClientCreatedOrder());
      // Update: restaurant owner (status changes), assigned courier, or admin
      allow update: if isPublicDemoOrderUpdate() || (isAuth() && (
        isClientCancelOnly() ||
        isClientReviewOnly() ||
        isRestaurantStatusOnly() ||
        isCourierAcceptOnly() ||
        isAssignedCourierDeliveryUpdate() ||
        isAdmin()
      ));
      // Only admins can delete orders
      allow delete: if isAdmin();
    }

    // =============================================
    // COURIERS COLLECTION
    // =============================================
    match /couriers/{courierId} {
      // Demo app connects by an admin-issued document ID. Profile writes remain restricted.
      allow get: if true;
      allow list: if isAuth();
      allow create: if (isAuth() && isOwner(courierId)) || courierId == 'courier-demo-1';
      allow update: if (isAuth() && (isOwner(courierId) || isAdmin())) ||
        isPublicCourierOperationalUpdate();
      allow delete: if isAdmin();

      match /earnings/{earningId} {
        allow read: if isAuth() && (isOwner(courierId) || isAdmin());
        allow write: if isAuth() && (isOwner(courierId) || isAdmin());
      }
    }

    // =============================================
    // PAYMENTS COLLECTION
    // =============================================
    match /payments/{paymentId} {
      // Read: payment owner or admin
      allow read: if isAuth() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      // Any authenticated user can create a payment
      allow create: if isAuth();
      // Only admins can update payments (refunds, etc.)
      allow update: if isAdmin();
      // Payments should never be deleted
      allow delete: if false;
    }

    // =============================================
    // SYSTEM SETTINGS
    // =============================================
    match /system_settings/{document=**} {
      // Any authenticated user can read settings (like delivery fees)
      allow read: if isAuth();
      // Only admins can modify settings
      allow write: if isAdmin();
    }

    match /settings/{document=**} {
      // Delivery pricing is public marketplace configuration.
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
