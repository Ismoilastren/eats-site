rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // HELPER FUNCTIONS
    // =============================================
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isBootstrapAdmin() {
      return isAuth() &&
        request.auth.token.email_verified == true &&
        request.auth.token.email in ['admin@2321eats.com', 'mainadmin@demo.com'];
    }

    function getUserRole() {
      let docRef = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(docRef) ? get(docRef).data.role : null;
    }

    function isAdmin() {
      return isBootstrapAdmin() || (isAuth() && getUserRole() in ['admin', 'superadmin', 'super_admin']);
    }

    function isOpsAdmin() {
      return isAuth() && getUserRole() in [
        'admin',
        'superadmin',
        'super_admin',
        'operator',
        'courier_manager',
        'restaurant_manager',
        'support',
        'analyst',
        'viewer'
      ];
    }

    function canReadAuditLogs() {
      return isAuth() && getUserRole() in ['admin', 'superadmin', 'super_admin', 'analyst'];
    }

    function isCourier() {
      return isAuth() && getUserRole() == 'courier';
    }

    function isCourierSessionFor(courierId) {
      return courierId is string &&
        courierId.size() > 0 &&
        (
          (
            isAuth() &&
            get(/databases/$(database)/documents/couriers/$(courierId)).data.sessionUid == request.auth.uid
          ) ||
          (
            get(/databases/$(database)/documents/couriers/$(courierId)).data.authProvider == 'courier-id' &&
            get(/databases/$(database)/documents/couriers/$(courierId)).data.sessionUid is string &&
            get(/databases/$(database)/documents/couriers/$(courierId)).data.sessionUid.size() > 0
          )
        );
    }

    function isConnectableCourierProfile() {
      return (!('archived' in resource.data) || resource.data.archived != true) &&
        (!('deleted' in resource.data) || resource.data.deleted != true) &&
        (!('isDeleted' in resource.data) || resource.data.isDeleted != true) &&
        (!('active' in resource.data) || resource.data.active != false) &&
        (!('isActive' in resource.data) || resource.data.isActive != false) &&
        (
          !('status' in resource.data) ||
          !(resource.data.status in ['archived', 'deleted', 'disabled', 'inactive', 'suspended'])
        );
    }

    function isCourierSessionClaim(courierId) {
      return isConnectableCourierProfile() &&
        (
          (
            isAuth() &&
            request.resource.data.sessionUid == request.auth.uid &&
            request.resource.data.authProvider == 'anonymous' &&
            (
              resource.data.sessionUid == null ||
              resource.data.sessionUid == request.auth.uid
            )
          ) ||
          (
            !isAuth() &&
            request.resource.data.sessionUid is string &&
            request.resource.data.sessionUid.matches('^courier_device_[A-Za-z0-9_]+$') &&
            request.resource.data.authProvider == 'courier-id'
          )
        ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'sessionUid',
          'authProvider',
          'lastSeenAt',
          'updatedAt'
        ]);
    }

    function isCourierSessionRelease(courierId) {
      return (isCourierSessionFor(courierId) || resource.data.authProvider == 'courier-id') &&
        request.resource.data.sessionUid == null &&
        request.resource.data.authProvider == null &&
        request.resource.data.status == 'offline' &&
        request.resource.data.isOnline == false &&
        request.resource.data.isAvailable == false &&
        request.resource.data.currentOrderId == null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'sessionUid',
          'authProvider',
          'status',
          'isOnline',
          'isAvailable',
          'currentOrderId',
          'lastSeenAt',
          'updatedAt'
        ]);
    }

    function isRestaurantOwner(restaurantId) {
      return isAuth() &&
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid;
    }

    function hasAssignedCourierId(data) {
      return data.assignedCourier is map &&
        data.assignedCourier.id is string &&
        data.assignedCourier.id.size() > 0;
    }

    function isAssignedCourier() {
      return isAuth() && (
        isCourierSessionFor(resource.data.courierId) ||
        (hasAssignedCourierId(resource.data) &&
          isCourierSessionFor(resource.data.assignedCourier.id))
      );
    }

    function isUnassignedRadarOrder() {
      return resource.data.status in ['preparing', 'ready_for_pickup'] &&
        resource.data.courierId == null &&
        resource.data.assignedCourier == null;
    }

    function isClientCreatedOrder() {
      return request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.courierId == null &&
        request.resource.data.assignedCourier == null;
    }

    function isValidOrderStatus(status) {
      return status in [
        'pending',
        'accepted',
        'preparing',
        'ready_for_pickup',
        'picked_up',
        'on_the_way',
        'delivered',
        'cancelled',
        'rejected'
      ];
    }

    function customerOrderIdentityMatches() {
      return isAuth() && (
        resource.data.userId == request.auth.uid ||
        (
          resource.data.customerEmail is string &&
          request.auth.token.email is string &&
          resource.data.customerEmail == request.auth.token.email
        ) ||
        (
          resource.data.customerPhone is string &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.phone is string &&
          resource.data.customerPhone == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.phone
        )
      );
    }

    function isPublicCourierOperationalUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'isOnline',
        'isAvailable',
        'currentLocation',
        'currentOrderId',
        'lastSeenAt',
        'updatedAt'
      ]) &&
      request.resource.data.status in ['offline', 'online', 'busy'] &&
      request.resource.data.isOnline is bool &&
      request.resource.data.isAvailable is bool &&
      (
        (request.resource.data.status == 'offline' &&
          request.resource.data.isOnline == false &&
          request.resource.data.isAvailable == false) ||
        (request.resource.data.status == 'online' &&
          request.resource.data.isOnline == true &&
          request.resource.data.isAvailable == true) ||
        (request.resource.data.status == 'busy' &&
          request.resource.data.isOnline == true &&
          request.resource.data.currentOrderId is string &&
          request.resource.data.isAvailable == false
        )
      );
    }

    function isClientCancelOnly() {
      return resource.data.userId == request.auth.uid &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'cancelled' &&
        request.resource.data.courierId == resource.data.courierId &&
        request.resource.data.assignedCourier == resource.data.assignedCourier &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'cancelledAt',
          'cancelReason',
          'updatedAt'
        ]);
    }

    function isClientReviewOnly() {
      return resource.data.userId == request.auth.uid &&
        resource.data.status == 'delivered' &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.courierId == resource.data.courierId &&
        request.resource.data.assignedCourier == resource.data.assignedCourier &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'review',
          'tipAmount',
          'updatedAt'
        ]);
    }

    function isCourierAcceptOnly() {
      return isCourierSessionFor(request.resource.data.courierId) &&
        isUnassignedRadarOrder() &&
        request.resource.data.status == resource.data.status &&
        hasAssignedCourierId(request.resource.data) &&
        request.resource.data.assignedCourier.id == request.resource.data.courierId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'courierId',
          'courierName',
          'courierPhone',
          'assignedCourier',
          'courier',
          'updatedAt'
        ]);
    }

    function isAssignedCourierDeliveryUpdate() {
      return isAssignedCourier() &&
        !(resource.data.status in ['delivered', 'cancelled', 'rejected']) &&
        request.resource.data.courierId == resource.data.courierId &&
        request.resource.data.assignedCourier == resource.data.assignedCourier &&
        request.resource.data.status in [
          'ready_for_pickup',
          'picked_up',
          'on_the_way',
          'delivered'
        ] &&
        (
          request.resource.data.status == resource.data.status ||
          (resource.data.status == 'ready_for_pickup' &&
            request.resource.data.status == 'picked_up') ||
          (resource.data.status == 'picked_up' &&
            request.resource.data.status == 'on_the_way') ||
          (resource.data.status == 'on_the_way' &&
            request.resource.data.status == 'delivered')
        ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'courierLocation',
          'deliveredAt',
          'updatedAt'
        ]);
    }

    function isValidSelfUserCreate(userId) {
      return isOwner(userId) &&
        (
          !('role' in request.resource.data) ||
          request.resource.data.role in ['client', 'customer', 'user']
        ) &&
        !('isAdmin' in request.resource.data) &&
        !('permissions' in request.resource.data);
    }

    function isValidSelfUserUpdate(userId) {
      return isOwner(userId) &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'role',
            'isAdmin',
            'permissions',
            'claims',
            'adminRole'
          ])
        );
    }

    function isRestaurantStatusOnly() {
      return isRestaurantOwner(resource.data.restaurantId) &&
        request.resource.data.restaurantId == resource.data.restaurantId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.courierId == resource.data.courierId &&
        request.resource.data.assignedCourier == resource.data.assignedCourier &&
        request.resource.data.status in [
          'pending',
          'accepted',
          'preparing',
          'ready_for_pickup',
          'cancelled',
          'rejected'
        ] &&
        (
          request.resource.data.status == resource.data.status ||
          (resource.data.status == 'pending' &&
            request.resource.data.status in ['accepted', 'cancelled', 'rejected']) ||
          (resource.data.status == 'accepted' &&
            request.resource.data.status in ['preparing', 'cancelled']) ||
          (resource.data.status == 'preparing' &&
            request.resource.data.status in ['ready_for_pickup', 'cancelled'])
        ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt'
        ]);
    }

    // =============================================
    // USERS COLLECTION
    // =============================================
    match /users/{userId} {
      // Users can read their own profile; admins can read all
      allow read: if isAuth() && (isOwner(userId) || isAdmin());
      // Users can create their own profile; admins can create managed accounts
      allow create: if isAdmin() || (isAuth() && isValidSelfUserCreate(userId));
      // Users can update their own profile; admins can update any
      allow update: if isAdmin() || (isAuth() && isValidSelfUserUpdate(userId));
      // Only admins can delete users
      allow delete: if isAdmin();

      match /addresses/{addressId} {
        allow read, create, update, delete: if isAuth() && isOwner(userId);
      }

      match /paymentMethods/{paymentMethodId} {
        allow read, create, update, delete: if isAuth() && isOwner(userId);
      }
    }

    // =============================================
    // RESTAURANTS COLLECTION
    // =============================================
    match /restaurants/{restaurantId} {
      // Public read — anyone can browse restaurants
      allow read: if true;
      // Only admins can create restaurants.
      allow create: if isAdmin();
      // Admins and bound restaurant owners can update restaurants.
      allow update: if isAdmin() || isRestaurantOwner(restaurantId);
      // Only admins can delete
      allow delete: if isAdmin();

      // Menu Items (subcollection)
      match /menuItems/{itemId} {
        // Public read
        allow read: if true;
        allow write: if isAdmin() || isRestaurantOwner(restaurantId);
      }

      match /dishes/{dishId} {
        allow read: if true;
        allow write: if isAdmin() || isRestaurantOwner(restaurantId);
      }
    }

    match /menuItems/{itemId} {
      allow read: if true;
      allow create: if isAdmin() || isRestaurantOwner(request.resource.data.restaurantId);
      allow update: if isAdmin() || isRestaurantOwner(resource.data.restaurantId);
      allow delete: if isAdmin();
    }

    match /promos/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =============================================
    // ORDERS COLLECTION
    // =============================================
    match /orders/{orderId} {
      // Read: order owner, assigned courier, restaurant owner, or admin
      allow read: if customerOrderIdentityMatches() ||
        isAssignedCourier() ||
        isRestaurantOwner(resource.data.restaurantId) ||
        isAdmin() ||
        isUnassignedRadarOrder();
      // Clients must create orders as pending and explicitly unassigned.
      allow create: if isAuth() && isClientCreatedOrder();
      // Update: restaurant owner (status changes), assigned courier, or admin
      allow update: if isValidOrderStatus(request.resource.data.status) && (
        isCourierAcceptOnly() ||
        (
          isAuth() && (
            isClientCancelOnly() ||
            isClientReviewOnly() ||
            isRestaurantStatusOnly() ||
            isAssignedCourierDeliveryUpdate() ||
            isAdmin()
          )
        )
      );
      // Only admins can delete orders
      allow delete: if isAdmin();
    }

    // =============================================
    // COURIERS COLLECTION
    // =============================================
    match /couriers/{courierId} {
      // Demo app connects by an admin-issued document ID. Profile writes remain restricted.
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        isCourierSessionClaim(courierId) ||
        isCourierSessionRelease(courierId) ||
        (isCourierSessionFor(courierId) && isPublicCourierOperationalUpdate());
      allow delete: if isAdmin();

      match /earnings/{earningId} {
        allow read: if isCourierSessionFor(courierId) || isAdmin();
        allow write: if isAdmin();
      }
    }

    // =============================================
    // PAYMENTS COLLECTION
    // =============================================
    match /payments/{paymentId} {
      // Read: payment owner or admin
      allow read: if isAuth() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      // Payment records must belong to the authenticated customer or be managed by admin.
      allow create: if isAuth() && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );
      // Only admins can update payments (refunds, etc.)
      allow update: if isAdmin();
      // Payments should never be deleted
      allow delete: if false;
    }

    // =============================================
    // SYSTEM SETTINGS
    // =============================================
    match /system_settings/{document=**} {
      // Any authenticated user can read settings (like delivery fees)
      allow read: if isAuth();
      // Only admins can modify settings
      allow write: if isAdmin();
    }

    match /settings/{document=**} {
      // Delivery pricing is public marketplace configuration.
      allow read: if true;
      allow write: if isAdmin();
    }

    // =============================================
    // ADMIN OPERATIONS: GEOZONES, ROLES, AUDIT LOGS
    // =============================================
    match /geozones/{zoneId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /system_categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /rolePermissions/{roleId} {
      allow read: if isOpsAdmin();
      allow write: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if canReadAuditLogs();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
