{
  "name": "express-eats",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:admin": "turbo run dev --filter=admin-panel",
    "dev:site": "turbo run dev --filter=main-site",
    "dev:client": "turbo run dev --filter=client-app",
    "dev:courier": "turbo run dev --filter=courier-app",
    "dev:restaurant": "turbo run dev --filter=restaurant-app",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "turbo": "^2.9.15",
    "prettier": "^3.4.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
